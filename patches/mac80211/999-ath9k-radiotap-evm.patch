ath9k/mac80211: emit per-frame stream-0 EVM as radiotap LOCK_QUALITY

ar9003 carries per-(stream,pilot) EVM in the RX descriptor (evm0..4).
Average the valid bytes (skip 0x80 "not measured" and 0 "unpopulated pilot
slot", the latter seen on very short frames) and report |EVM| in dB (higher =
better, like SNR) via a new ieee80211_rx_status.evm field, emitted as the
aggregate IEEE80211_RADIOTAP_LOCK_QUALITY (bit 7) so wfb-ng reports per-antenna
EVM. For single-stream frames the survivors are exactly stream-0 pilots.
Applies after the antnoise patch.

--- a/include/net/mac80211.h
+++ b/include/net/mac80211.h
@@ -1679,6 +1679,7 @@
 	u8 antenna;
 	s8 signal;
 	s8 noise;	/* NF in dBm; 0 = not present (ath9k radiotap antnoise) */
+	u8 evm;		/* |EVM| in dB, higher = better; 0 = absent (radiotap LOCK_QUALITY) */
 	u8 chains;
 	s8 chain_signal[IEEE80211_MAX_CHAINS];
 	u8 zero_length_psdu_type;
--- a/drivers/net/wireless/ath/ath9k/common.c
+++ b/drivers/net/wireless/ath/ath9k/common.c
@@ -211,6 +211,34 @@
 }
 EXPORT_SYMBOL(ath9k_cmn_process_rate);
 
+/* Average the valid per-pilot EVM-magnitude bytes from the ar9003 RX
+ * descriptor and return |EVM| in dB (higher = better, like SNR); 0 = absent.
+ * Bytes equal to 0x80 ("not measured") or 0 (unpopulated pilot slot, seen on
+ * very short frames) are skipped. For single-stream frames the survivors are
+ * exactly stream-0's pilots, so no (stream,pilot) interleave decode is needed;
+ * legacy frames are all-0x80. Keep in sync with tests/ath9k_evm_test.c. */
+static u8 ath9k_cmn_evm_db(u32 e0, u32 e1, u32 e2, u32 e3, u32 e4)
+{
+	u32 words[4] = { e0, e1, e2, e3 };
+	u32 sum = 0, n = 0;
+	int w, b;
+
+	for (w = 0; w < 4; w++)
+		for (b = 0; b < 4; b++) {
+			u8 v = (words[w] >> (8 * b)) & 0xff;
+			if (v != 0x80 && v != 0) { sum += v; n++; }
+		}
+	for (b = 0; b < 2; b++) {
+		u8 v = (e4 >> (8 * b)) & 0xff;
+		if (v != 0x80 && v != 0) { sum += v; n++; }
+	}
+
+	if (n == 0)
+		return 0;
+
+	return (u8)(sum / n);
+}
+
 void ath9k_cmn_process_rssi(struct ath_common *common,
 			    struct ieee80211_hw *hw,
 			    struct ath_rx_status *rx_stats,
@@ -271,6 +299,9 @@
 
 	rxs->signal = ah->noise + rx_stats->rs_rssi;
 	rxs->noise = ah->noise;
+	rxs->evm = ath9k_cmn_evm_db(rx_stats->evm0, rx_stats->evm1,
+				    rx_stats->evm2, rx_stats->evm3,
+				    rx_stats->evm4);
 }
 EXPORT_SYMBOL(ath9k_cmn_process_rssi);
 
--- a/net/mac80211/rx.c
+++ b/net/mac80211/rx.c
@@ -139,6 +139,13 @@
 	if (status->noise)
 		len += 1;
 
+	/* IEEE80211_RADIOTAP_LOCK_QUALITY (u16, 2-byte aligned) */
+	if (status->evm) {
+		if (len & 1)
+			len++;
+		len += 2;
+	}
+
 	/* antenna field, if we don't have per-chain info */
 	if (!status->chains)
 		len += 1;
@@ -476,7 +483,15 @@
