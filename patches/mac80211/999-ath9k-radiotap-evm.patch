 }
 EXPORT_SYMBOL(ath9k_cmn_process_rate);
 
+/* byte->percent scale: 3/1 if descriptor bytes are |EVM_dB| (Realtek scale),
+ * 3/2 if they are half-dB units. Confirmed by the on-air calibration step. */
+#define EVM_K_NUM 3
+#define EVM_K_DEN 1
+
+/* Average all valid (non-0x80) per-pilot EVM bytes from the ar9003 RX
+ * descriptor and map to a 0-100 quality percent (0 = absent). For
+ * single-stream frames the survivors are exactly stream-0's pilots, so no
+ * (stream,pilot) interleave decode is needed; legacy frames are all-0x80.
+ * Keep in sync with tests/ath9k_evm_test.c (host unit test). */
+static u8 ath9k_cmn_evm_percent(u32 e0, u32 e1, u32 e2, u32 e3, u32 e4)
+{
+	u32 words[4] = { e0, e1, e2, e3 };
+	u32 sum = 0, n = 0, avg, pct;
+	int w, b;
+
+	for (w = 0; w < 4; w++)
+		for (b = 0; b < 4; b++) {
+			u8 v = (words[w] >> (8 * b)) & 0xff;
+			if (v != 0x80) { sum += v; n++; }
+		}
+	for (b = 0; b < 2; b++) {
+		u8 v = (e4 >> (8 * b)) & 0xff;
+		if (v != 0x80) { sum += v; n++; }
+	}
+
+	if (n == 0)
+		return 0;
+
+	avg = sum / n;
+	pct = (EVM_K_NUM * avg) / EVM_K_DEN;
+	if (pct > 100)
+		pct = 100;
+	if (pct < 1)
+		pct = 1;
+	return (u8)pct;
+}
+
 void ath9k_cmn_process_rssi(struct ath_common *common,
 			    struct ieee80211_hw *hw,
 			    struct ath_rx_status *rx_stats,
@@ -271,6 +309,9 @@
 
 	rxs->signal = ah->noise + rx_stats->rs_rssi;
 	rxs->noise = ah->noise;
+	rxs->evm = ath9k_cmn_evm_percent(rx_stats->evm0, rx_stats->evm1,
+					 rx_stats->evm2, rx_stats->evm3,
+					 rx_stats->evm4);
 }
 EXPORT_SYMBOL(ath9k_cmn_process_rssi);
 
